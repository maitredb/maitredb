{
  "name": "@maitredb/driver-postgres",
  "version": "0.1.0",
  "description": "PostgreSQL driver for Maître d'B",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
