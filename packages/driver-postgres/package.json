    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@maitredb/core": "workspace:*",
    "@maitredb/plugin-api": "workspace:*",
    "pg": "^8.12.0",
    "pg-cursor": "^2.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/pg": "^8.11.6",
    "@types/pg-cursor": "^2.7.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@maitredb/plugin-api": "0.1.0"
  }
}